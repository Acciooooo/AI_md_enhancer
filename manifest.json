{
  "manifest_version": 3,
  "name": "AI Markdown Enhancer",
  "version": "1.5.0",
  "description": "Adds a Markdown editor with live preview and LaTeX math to DeepSeek, ChatGPT, Doubao, Gemini, Kimi, and more.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "AI Markdown Enhancer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chat.deepseek.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*",
        "https://gemini.google.com/*",
        "https://www.kimi.com/*",
        "https://kimi.com/*",
        "https://kimi.moonshot.cn/*"
      ],
      "js": ["katex/katex.min.js", "marked.min.js", "content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "katex/katex.min.css",
        "katex/fonts/*"
      ],
      "matches": [
        "https://chat.deepseek.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*",
        "https://gemini.google.com/*",
        "https://www.kimi.com/*",
        "https://kimi.com/*",
        "https://kimi.moonshot.cn/*"
      ]
    }
  ],
  "host_permissions": [
    "https://chat.deepseek.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://www.doubao.com/*",
    "https://doubao.com/*",
    "https://gemini.google.com/*",
    "https://www.kimi.com/*",
    "https://kimi.com/*",
    "https://kimi.moonshot.cn/*"
  ]
}
